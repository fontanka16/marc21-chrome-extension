{
  "manifest_version": 3,
  "name": "MARC21 Viewer",
  "version": "1.2.0",
  "description": "Öppnar MARC21-poster (.mrc, .marc) och Libris _compilemarc-länkar. Klicka på ikonen för att välja en lokal fil.",
  "permissions": [
    "contextMenus",
    "storage"
  ],
  "host_permissions": [
    "*://libris.kb.se/*"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "MARC21 Viewer"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
